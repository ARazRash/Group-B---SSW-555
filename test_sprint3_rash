import unittest
from datetime import date

from gedcom_report import (
    no_family_bigamy,
    parents_not_too_old,
    parse_gedcom
)

def parse_sample(text):
    return parse_gedcom(text.strip().splitlines())

class Sprint3RashTest(unittest.TestCase):
    def test_no_family_bigamy(self):
        no_bigamy_sample = [
        "0 @I5@ INDI",
        "1 NAME Lexis Willows",
        "1 SEX F",
        "1 BIRT",
        "2 DATE 30 APR 1985",
        "1 FAMS @F2@",
        "1 FAMS @F4@",

        "0 @F4@ FAM",
        "1 HUSB @I8@",
        "1 WIFE @I5@",
        "1 MARR",
        "2 DATE 1 JUN 2004",
        "1 DIV",
        "2 DATE 1 SEP 2006"
        ]

        individuals, families = parse_gedcom(no_bigamy_sample)
        rows = no_family_bigamy(families, individuals)
        self.assertEqual(rows, [])

    def test_bigamy_exists(self):
        bigamy_sample = [
            "0 @I5@ INDI",
            "1 NAME Lexis Willows",
            "1 SEX F",
            "1 BIRT",
            "2 DATE 30 APR 1985",
            "1 FAMS @F2@",
            "1 FAMS @F4@",

            "0 @I8@ INDI",
            "1 NAME Montana Front",
            "1 SEX M",
            "1 BIRT",
            "2 DATE 2 AUG 1984",
            "1 FAMS @F4@",

            "0 @F4@ FAM",
            "1 HUSB @I8@",
            "1 WIFE @I5@",
            "1 MARR",
            "2 DATE 1 JUN 2004",

            "0 @F2@ FAM",
            "1 HUSB @I3@",
            "1 WIFE @I5@",
            "1 MARR",
            "2 DATE 1 JUN 2005"
        ]
        individuals, families = parse_gedcom(bigamy_sample)
        rows = no_family_bigamy(families, individuals)

        print(rows)

        self.assertEqual(len(rows), 1)
        self.assertEqual(rows[0][1], "US11")

